<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Exercício 2 - Programação em Par</title>
    <style>
        /* Visual baseado no programacao-em-par.html (tudo junto) */
        * {
            box-sizing: border-box;
            font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: stretch;
            justify-content: center;
            background: #212121;
            color: #FFFCF7;
        }

        .app {
            width: 100%;
            max-width: 1180px;
            height: 100vh;
            background:
                radial-gradient(circle at top left, rgba(222, 81, 20, 0.16), transparent 55%),
                radial-gradient(circle at bottom right, rgba(20, 114, 222, 0.1), transparent 55%),
                #181818;
            box-shadow:
                0 22px 45px rgba(0, 0, 0, 0.9),
                0 0 0 1px rgba(255, 252, 247, 0.06);
            padding: 24px 28px 26px;
            display: grid;
            grid-template-columns: 3fr 2fr;
            gap: 24px;
        }

        @media (max-width: 820px) {
            .app { grid-template-columns: 1fr; }
        }

        section { display: flex; flex-direction: column; }

        h1 {
            margin: 0 0 8px;
            font-size: 1.4rem;
            letter-spacing: 0.02em;
        }

        .subtitle {
            margin: 0 0 20px;
            font-size: 0.9rem;
            color: #a0a0a0;
            line-height: 1.35;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 3px 10px;
            border-radius: 999px;
            background: rgba(33, 33, 33, 0.9);
            border: 1px solid rgba(222, 81, 20, 0.6);
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.09em;
            color: #FFFCF7;
            width: fit-content;
        }

        .badge span {
            width: 5px;
            height: 5px;
            border-radius: 999px;
            background: #DE5114;
        }

        .card {
            background: radial-gradient(circle at top, rgba(222, 81, 20, 0.22), transparent 55%);
            border-radius: 14px;
            border: 1px solid rgba(222, 81, 20, 0.55);
            padding: 16px 18px 14px;
        }

        .card-title {
            font-size: 0.9rem;
            margin: 0 0 4px;
            color: #FFFCF7;
        }

        .card-text {
            margin: 0;
            font-size: 0.8rem;
            color: #e5e5e5;
            line-height: 1.35;
        }

        form {
            margin-top: 16px;
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px 14px;
        }

        .field {
            display: flex;
            flex-direction: column;
            gap: 4px;
            font-size: 0.8rem;
        }

        label { color: #FFFCF7; }

        input, select {
            border-radius: 9px;
            border: 1px solid rgba(255, 252, 247, 0.16);
            background: rgba(12, 12, 12, 0.96);
            padding: 7px 9px;
            font-size: 0.8rem;
            color: #FFFCF7;
        }

        input:focus, select:focus {
            outline: 2px solid rgba(222, 81, 20, 0.9);
            outline-offset: 1px;
            border-color: rgba(222, 81, 20, 0.9);
        }

        .buttons {
            grid-column: 1 / -1;
            display: flex;
            gap: 8px;
            margin-top: 4px;
        }

        .btn {
            flex: 1;
            border-radius: 999px;
            border: 0;
            padding: 7px 10px;
            font-size: 0.8rem;
            font-weight: 500;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

        .btn-primary {
            background: linear-gradient(to right, #DE5114, #c84a12);
            color: white;
            box-shadow: 0 10px 25px rgba(222, 81, 20, 0.65);
        }

        .btn-secondary {
            background: rgba(33, 33, 33, 0.9);
            color: #FFFCF7;
            border: 1px solid rgba(222, 81, 20, 0.65);
        }

        .btn-ghost {
            background: rgba(12, 12, 12, 0.9);
            color: #FFFCF7;
            border: 1px dashed rgba(222, 81, 20, 0.65);
        }

        .btn span.icon {
            width: 16px;
            height: 16px;
            border-radius: 999px;
            background: rgba(0, 0, 0, 0.85);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
        }

        .log-panel {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
            font-size: 0.72rem;
            background: radial-gradient(circle at top left, rgba(222, 81, 20, 0.25), transparent 60%);
            border-radius: 14px;
            border: 1px solid rgba(222, 81, 20, 0.7);
            padding: 14px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            height: 100%;
        }

        .log-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .log-title { font-size: 0.8rem; color: #FFFCF7; }
        .log-counter { font-size: 0.7rem; color: #a0a0a0; }

        .log-body {
            background: rgba(0, 0, 0, 0.9);
            border-radius: 10px;
            border: 1px solid rgba(222, 81, 20, 0.45);
            padding: 8px;
            min-height: 0;
            flex: 1;
            overflow: auto;
        }

        .log-line { white-space: pre-wrap; color: #FFFCF7; }
        .log-line--info { color: #ffe0cc; }
        .log-line--warning { color: #fedf89; }
        .log-line--error { color: #ff9b9b; }

        .hint {
            font-size: 0.7rem;
            color: #a0a0a0;
            margin-top: auto;
            line-height: 1.35;
        }
    </style>
</head>
<body>
    <div class="app">
        <section>
            <div class="badge"><span></span>Par Programming · Exercício 2</div>
            <h1>Calculadora simples</h1>
            <p class="subtitle">
                Exercício bem simples: calcular com dois números e registrar logs.
                O JavaScript está <strong>ruim de propósito</strong> para vocês refatorarem (DRY + refatoração).
            </p>

            <div class="card">
                <p class="card-title">Tarefa</p>
                <p class="card-text">
                    Sem mudar o HTML: reduzir duplicação, criar funções reutilizáveis (pegar dados, validar, calcular, logar).
                    Mantenha o comportamento igual.
                </p>
            </div>

            <form id="formCalc">
                <div class="form-grid">
                    <div class="field">
                        <label for="a">Número A</label>
                        <input id="a" type="number" step="1" placeholder="Ex.: 10" />
                    </div>
                    <div class="field">
                        <label for="b">Número B</label>
                        <input id="b" type="number" step="1" placeholder="Ex.: 3" />
                    </div>
                    <div class="field">
                        <label for="op">Operação</label>
                        <select id="op">
                            <option value="+">Somar (+)</option>
                            <option value="-">Subtrair (-)</option>
                            <option value="*">Multiplicar (*)</option>
                            <option value="/">Dividir (/)</option>
                        </select>
                    </div>
                    <div class="field">
                        <label for="repetir">Repetir (simulação)</label>
                        <input id="repetir" type="number" step="1" value="3" />
                    </div>

                    <div class="buttons">
                        <button type="button" id="btnCalcular" class="btn btn-primary">
                            <span class="icon">=</span>
                            Calcular
                        </button>
                        <button type="button" id="btnSimular" class="btn btn-secondary">
                            <span class="icon">≋</span>
                            Simular
                        </button>
                        <button type="button" id="btnLimpar" class="btn btn-ghost">
                            <span class="icon">⟳</span>
                            Limpar
                        </button>
                    </div>
                </div>

                <p class="hint">
                    Dica: extraia funções como <code>coletar()</code>, <code>validar()</code>, <code>calcular()</code>, <code>log()</code>.
                </p>
            </form>
        </section>

        <aside class="log-panel">
            <div class="log-header">
                <div class="log-title">Console (versão para alunos)</div>
                <div class="log-counter" id="contadorLogs">0 logs</div>
            </div>
            <div class="log-body" id="areaLogs"></div>
            <div class="hint">
                Regra: o botão Simular repete o cálculo N vezes e soma os resultados.
            </div>
        </aside>
    </div>

    <script>

        var logs = 0;
        function cont() {
            document.getElementById("contadorLogs").textContent = logs + (logs === 1 ? " log" : " logs");
        }

        function logar(msg, tipo) {
            var area = document.getElementById("areaLogs");
            var l = document.createElement("div");
            l.className = "log-line log-line--" + (tipo || "info");
            l.textContent = msg;
            area.appendChild(l);
            logs = logs + 1;
            cont();
            area.scrollTop = area.scrollHeight;
        }

        var btnCalcular= document.getElementById("btnCalcular");
        var btnSimular= document.getElementById("btnSimular");
        var a = document.getElementById("a").value;
        var b = document.getElementById("b").value;

        if (a === "" || b === "") {
            logar("ERRO: preencha A e B.", "error");
            return;
        }

        var aa = parseFloat(a);
        var bb = parseFloat(b);
        if (isNaN(aa) || isNaN(bb)) {
            logar("ERRO: números inválidos.", "error");
            return;
        }

        var op = document.getElementById("op").value;
        var rep = document.getElementById("repetir").value;

        function calcular(aa, bb, op) {
            switch (op) {
                case "+": return aa + bb;
                case "-": return aa - bb;
                case "*": return aa * bb;
                case "/":
                    if (bb === 0) return null;
                    return aa / bb;
                default:
                    return null;
            }
        }
    




